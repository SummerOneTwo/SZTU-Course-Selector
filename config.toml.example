# ============================================================
# SZTU 抢课脚本配置文件示例 (请将此文件复刻为 config.toml 并填写真实信息)
# ============================================================

[account]
username = "202400000000"
password = "你的教务系统密码"

# ============================================================
# 课程配置
# 每个 [[courses]] 代表一门想抢的课
# 同一门课的多个教学班写在 jx0404id 数组里，抢到任意一个即完成
# 要抢多门课就写多个 [[courses]] 块
# ============================================================

[[courses]]
name = "大学物理实验B2"           # 课程名（仅用于日志显示，随便写）
kcid = "794AE26A58E546C593465C70E6FB9771"
cno = "1"                         # 选课类型: "0"=必选计划, "1"=跨年级
jx0404id = [
    "202520262001768",
    "202520262001256",
    "202520262001765",
    "202520262001766",
    "202520262001767",
]

# [[courses]]
# name = "另一门课"
# kcid = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# cno = "0"
# jx0404id = ["YYYYYYYYYYYYYYY"]

# ============================================================
# 运行设置
# ============================================================

[settings]
# 运行模式: "monitor" = 首抢模式, "scavenge" = 捡漏模式
mode = "scavenge"

# 要抢几门课（达到此数量后自动停止）
target_count = 1

# 选课批次ID（捡漏模式必填；首抢模式会自动从 xklc_list 获取新ID）
jx0502zbid = "7C6165D5AA8C4186B396ECBAC1CFF57D"

# 并发线程数（建议 4-16）
max_workers = 8

# 捡漏模式：每轮失败后等待的秒数范围
round_cool_down_min = 280
round_cool_down_max = 320

# 运行时间窗口（仅在此时段内运行，窗口外自动休眠）
schedule_start = "08:55"
schedule_end = "22:00"
